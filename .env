# ── LLM Model Configuration ──
# All copilot CLI calls will use this model.
# Available: gpt-5-mini, gpt-4.1, claude-haiku-4.5, claude-sonnet-4.6, etc.
COPILOT_MODEL=gpt-5-mini

# ── History Truncation ──
# Number of most-recent workflow_progress entries to keep FULL (no truncation).
# Older entries are truncated to 500 chars.
# e.g. 3 means the latest 3 entries are shown in full, the rest are truncated.
HISTORY_KEEP_FULL=3
